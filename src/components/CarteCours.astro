---
// On récupère les propriétés du Markdown
const { title, icone, rentabilite, discipline } = Astro.props;
---

<div class="glass-card">
  <div class="card-header">
    <span class="badge">{discipline}</span>
    <span class="icon">{icone}</span>
  </div>
  
  <h1>{title}</h1>
  
  <div class="rating">
    Rentabilité : {Array(rentabilite).fill('★').join('')}
  </div>

  <hr />

  <div class="content">
    <slot /> </div>
</div>

<style>
  .glass-card {
    background: rgba(255, 255, 255, 0.1);
    backdrop-filter: blur(10px);
    border: 1px solid rgba(255, 255, 255, 0.2);
    border-radius: 20px;
    padding: 2rem;
    color: white;
    box-shadow: 0 8px 32px 0 rgba(31, 38, 135, 0.37);
    transition: 0.3s ease;
  }

  .glass-card:hover {
    transform: translateY(-10px);
    border-color: #4f46e5;
  }

  .badge {
    background: #4f46e5;
    padding: 4px 12px;
    border-radius: 20px;
    font-size: 0.8rem;
  }

  h1 { margin: 1rem 0; font-size: 2rem; }
  .rating { color: #fbbf24; margin-bottom: 1rem; }
  hr { border: 0; border-top: 1px solid rgba(255,255,255,0.1); margin: 1.5rem 0; }
</style>