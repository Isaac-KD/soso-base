---
/**
 * MatieresGrid.astro
 *
 * Responsive grid listing all matieres.
 * Delegates per-card rendering to MatiereCard so the grid
 * stays focused on layout and the card handles its own style.
 */

import type { Matiere } from '../../types';
import MatiereCard from '../ui/MatiereCard.astro';

interface Props {
  matieres: Matiere[];
  manageHref?: string;
}

const { matieres, manageHref = '/matieres' } = Astro.props;
---

<section class="matieres-section animate-fade-up-delay-2" aria-label="Mes matières">
  <div class="section-header">
    <h2 class="section-title">Mes matières</h2>
    <a href={manageHref} class="section-link">Gérer →</a>
  </div>

  <ul class="matieres-grid" role="list">
    {matieres.map((m: Matiere) => (
      <li>
        <MatiereCard {...m} />
      </li>
    ))}
  </ul>
</section>

<style>
  /* ── Header ────────────────────────────────────── */
  .section-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: var(--space-4);
  }

  .section-title {
    font-family: var(--font-serif);
    font-size: 18px;
    font-weight: 400;
    letter-spacing: 0.01em;
    color: var(--color-text);
  }

  .section-link {
    font-size: 12px;
    color: var(--color-text-dim);
    text-decoration: none;
    transition: color var(--duration-base);
  }

  .section-link:hover { color: var(--color-text); }

  /* ── Grid ──────────────────────────────────────── */
  .matieres-grid {
    list-style: none;
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 14px;
  }

  /* ── Responsive ────────────────────────────────── */
  @media (max-width: 1100px) {
    .matieres-grid { grid-template-columns: repeat(2, 1fr); }
  }

  @media (max-width: 640px) {
    .matieres-grid { grid-template-columns: 1fr; }
  }
</style>
