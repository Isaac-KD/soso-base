---
/**
 * KnowledgeGraphPanel.astro
 *
 * Wraps KnowledgeGraph inside a titled panel with a "Voir tout" link.
 * Separating the panel chrome from the graph itself keeps both reusable.
 */

import type { Matiere, FicheRecente } from '../../types';
import KnowledgeGraph from './KnowledgeGraph.astro';

interface Props {
  matieres: Matiere[];
  ficheRecentes: FicheRecente[];
  viewAllHref?: string;
}

const { matieres, ficheRecentes, viewAllHref = '/tous' } = Astro.props;
---

<section class="panel" aria-label="Graphe des connaissances">
  <div class="panel__header">
    <h2 class="panel__title">Graphe des connaissances</h2>
    <a href={viewAllHref} class="panel__link">Voir tout →</a>
  </div>

  <KnowledgeGraph matieres={matieres} ficheRecentes={ficheRecentes} />
</section>

<style>
  .panel {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    padding: var(--space-6);
  }

  .panel__header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: var(--space-5);
  }

  .panel__title {
    font-family: var(--font-serif);
    font-size: 18px;
    font-weight: 400;
    letter-spacing: 0.01em;
    color: var(--color-text);
  }

  .panel__link {
    font-size: 12px;
    color: var(--color-text-dim);
    text-decoration: none;
    transition: color var(--duration-base);
  }

  .panel__link:hover { color: var(--color-text); }
</style>
