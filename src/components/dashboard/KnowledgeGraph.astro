---
/**
 * KnowledgeGraph.astro
 *
 * Interactive D3 force-directed graph of matieres and fiches.
 * All D3 logic is scoped to this component — the parent just
 * passes data and this component handles its own rendering.
 *
 * The graph is purely decorative/explorative; all data is
 * serialised into the page via `define:vars` so no extra
 * network request is needed.
 */

import type { Matiere, FicheRecente } from '../../types';

interface Props {
  matieres: Matiere[];
  ficheRecentes: FicheRecente[];
}

const { matieres, ficheRecentes } = Astro.props;

/** Number of ghost nodes added to enrich the graph visually */
const GHOST_NODE_COUNT = 50;
const NODE_PREFIXES    = ['Chapitre', 'Exo', 'Brouillon', 'Concept', 'Théorème', 'Note'];
---

<div class="graph-container" id="knowledge-graph" aria-label="Graphe des connaissances"></div>

<script define:vars={{ matieres, ficheRecentes, GHOST_NODE_COUNT, NODE_PREFIXES }}>
/**
 * D3 force-directed graph.
 * Loaded dynamically to avoid blocking the page render.
 */
(async () => {
  const d3 = await import('https://cdn.jsdelivr.net/npm/d3@7/+esm');

  // ── Build nodes and links ─────────────────────────────────────────────────

  /** @type {Array<{id:string, label:string, radius:number, color:string, type:string}>} */
  const nodes = [];
  /** @type {Array<{source:string, target:string}>} */
  const links = [];

  // Matière nodes (large hubs)
  for (const m of matieres) {
    nodes.push({ id: m.nom, label: m.nom, radius: 14, color: m.couleur, type: 'matiere' });
  }

  // Recent fiche nodes
  for (const f of ficheRecentes) {
    nodes.push({ id: f.titre, label: f.titre, radius: 7, color: f.couleur, type: f.type });
    links.push({ source: f.titre, target: f.matiere });
  }

  // Ghost nodes (decorative density)
  for (let i = 0; i < GHOST_NODE_COUNT; i++) {
    const m    = matieres[Math.floor(Math.random() * matieres.length)];
    const id   = `${NODE_PREFIXES[Math.floor(Math.random() * NODE_PREFIXES.length)]} ${i + 1}`;
    nodes.push({ id, label: '', radius: Math.random() * 4 + 3, color: m.couleur, type: 'ghost' });
    links.push({ source: id, target: m.nom });
  }

  // ── DOM setup ─────────────────────────────────────────────────────────────

  const container = document.getElementById('knowledge-graph');
  const W = container.clientWidth  || 600;
  const H = container.clientHeight || 300;

  container.innerHTML = '';

  const rootSvg = d3.select('#knowledge-graph')
    .append('svg')
    .attr('width',   '100%')
    .attr('height',  '100%')
    .attr('viewBox', `0 0 ${W} ${H}`)
    .call(
      d3.zoom()
        .scaleExtent([0.3, 4])
        .on('zoom', (event) => g.attr('transform', event.transform))
    );

  const g = rootSvg.append('g');

  // ── Simulation ────────────────────────────────────────────────────────────

  const simulation = d3.forceSimulation(nodes)
    .force('link',    d3.forceLink(links).id((d) => d.id).distance(20))
    .force('charge',  d3.forceManyBody().strength(-50).distanceMax(150))
    .force('center',  d3.forceCenter(W / 2, H / 2))
    .force('collide', d3.forceCollide().radius((d) => d.radius + 2))
    .force('x',       d3.forceX(W / 2).strength(0.06))
    .force('y',       d3.forceY(H / 2).strength(0.06));

  // ── Rendering ─────────────────────────────────────────────────────────────

  const link = g.append('g')
    .selectAll('line')
    .data(links)
    .join('line')
    .attr('stroke',         '#3d3a50')
    .attr('stroke-width',   1)
    .attr('stroke-opacity', 0.4);

  const node = g.append('g')
    .selectAll('circle')
    .data(nodes)
    .join('circle')
    .attr('r',            (d) => d.radius)
    .attr('fill',         (d) => d.color)
    .attr('stroke',       '#16161d')
    .attr('stroke-width', 1.5)
    .call(drag(simulation));

  const label = g.append('g')
    .selectAll('text')
    .data(nodes.filter((n) => n.label !== ''))
    .join('text')
    .text((d) => d.label)
    .attr('font-family', 'Outfit, sans-serif')
    .attr('font-size',   (d) => d.type === 'matiere' ? '13px' : '11px')
    .attr('font-weight', (d) => d.type === 'matiere' ? '500' : '300')
    .attr('fill',        '#e8e4da')
    .attr('dx',          (d) => d.radius + 6)
    .attr('dy',          4)
    .style('pointer-events', 'none')
    .style('opacity',        0.9)
    .style('text-shadow',    '0 1px 3px rgba(0,0,0,0.8)');

  // ── Tick ──────────────────────────────────────────────────────────────────

  simulation.on('tick', () => {
    link
      .attr('x1', (d) => d.source.x)
      .attr('y1', (d) => d.source.y)
      .attr('x2', (d) => d.target.x)
      .attr('y2', (d) => d.target.y);

    node
      .attr('cx', (d) => d.x)
      .attr('cy', (d) => d.y);

    label
      .attr('x', (d) => d.x)
      .attr('y', (d) => d.y);
  });

  // ── Drag ──────────────────────────────────────────────────────────────────

  /** @param {any} simulation */
  function drag(simulation) {
    return d3.drag()
      .on('start', (event) => {
        if (!event.active) simulation.alphaTarget(0.3).restart();
        event.subject.fx = event.subject.x;
        event.subject.fy = event.subject.y;
        container.style.cursor = 'grabbing';
      })
      .on('drag', (event) => {
        event.subject.fx = event.x;
        event.subject.fy = event.y;
      })
      .on('end', (event) => {
        if (!event.active) simulation.alphaTarget(0);
        event.subject.fx = null;
        event.subject.fy = null;
        container.style.cursor = 'grab';
      });
  }
})().catch((err) => console.error('[KnowledgeGraph] D3 load failed:', err));
</script>

<style>
  .graph-container {
    width: 100%;
    height: 300px;
    background: var(--color-surface-2);
    border-radius: var(--radius-sm);
    overflow: hidden;
    cursor: grab;
  }
</style>
