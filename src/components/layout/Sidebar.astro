---
/**
 * Sidebar.astro
 *
 * Primary navigation sidebar.
 * Receives the active route so it can highlight the current item.
 */

import type { NavItem } from '../../types';
import { NAV_ITEMS, NAV_BOTTOM } from '../../data/studyvault';

interface Props {
  /** Current page pathname, e.g. "/" or "/fiches" */
  activePath?: string;
}

const { activePath = '/' } = Astro.props;

const isActive = (href: string) => href === activePath;
---

<aside class="sidebar" aria-label="Navigation principale">
  <!-- Logo -->
  <div class="logo">
    <span class="logo-mark" aria-hidden="true">S</span>
    <span class="logo-text">StudyVault</span>
  </div>

  <!-- Primary nav -->
  <nav>
    <ul class="nav-list" role="list">
      {NAV_ITEMS.map((item: NavItem) => (
        <li>
          <a
            href={item.href}
            class:list={['nav-item', { 'nav-item--active': isActive(item.href) }]}
            aria-current={isActive(item.href) ? 'page' : undefined}
          >
            <span class="nav-icon" aria-hidden="true">{item.icon}</span>
            <span>{item.label}</span>
          </a>
        </li>
      ))}
    </ul>
  </nav>

  <!-- Bottom actions (settings, etc.) -->
  <div class="nav-bottom">
    {NAV_BOTTOM.map((item: NavItem) => (
      <a href={item.href} class="nav-item">
        <span class="nav-icon" aria-hidden="true">{item.icon}</span>
        <span>{item.label}</span>
      </a>
    ))}
  </div>
</aside>

<style>
  /* ── Shell ─────────────────────────────────────── */
  .sidebar {
    width: var(--sidebar-width);
    min-height: 100vh;
    position: sticky;
    top: 0;
    height: 100vh;
    flex-shrink: 0;

    display: flex;
    flex-direction: column;
    padding: var(--space-8) var(--space-4);
    gap: var(--space-2);

    background: var(--color-surface);
    border-right: 1px solid var(--color-border);
    overflow-y: auto;
  }

  /* ── Logo ──────────────────────────────────────── */
  .logo {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    padding: 0 var(--space-2) var(--space-8);
    border-bottom: 1px solid var(--color-border);
    margin-bottom: var(--space-5);
    flex-shrink: 0;
  }

  .logo-mark {
    width: 34px;
    height: 34px;
    border-radius: var(--radius-md);
    background: linear-gradient(135deg, #7C9EC9, #B07CC9);
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-serif);
    font-size: 18px;
    font-weight: 600;
    color: #fff;
    flex-shrink: 0;
  }

  .logo-text {
    font-family: var(--font-serif);
    font-size: 17px;
    font-weight: 600;
    letter-spacing: 0.02em;
    color: var(--color-text);
  }

  /* ── Nav list ──────────────────────────────────── */
  .nav-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 2px;
    flex: 1;
  }

  /* ── Nav item ──────────────────────────────────── */
  .nav-item {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    padding: 9px var(--space-3);
    border-radius: var(--radius-sm);
    color: var(--color-text-dim);
    font-size: 14px;
    font-weight: 400;
    text-decoration: none;
    transition:
      background var(--duration-base),
      color var(--duration-base);
  }

  .nav-item:hover,
  .nav-item--active {
    background: var(--color-surface-2);
    color: var(--color-text);
  }

  .nav-item--active {
    font-weight: 500;
  }

  .nav-icon {
    font-size: 15px;
    width: 18px;
    text-align: center;
    flex-shrink: 0;
  }

  /* ── Bottom section ────────────────────────────── */
  .nav-bottom {
    border-top: 1px solid var(--color-border);
    padding-top: var(--space-4);
    margin-top: var(--space-2);
    flex-shrink: 0;
  }
</style>
