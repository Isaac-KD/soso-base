---
import type { NavSection } from '../../types';
import '../../styles/components/sidebar.css';

interface Props {
  sections: NavSection[];
}

const { sections = [] } = Astro.props;

// 1. On récupère le chemin de la page actuelle (ex: "/", "/liens", etc.)
const currentPath = Astro.url.pathname;

// 2. Petite fonction pour vérifier si un lien est actif
const isItemActive = (href?: string) => {
  if (!href) return false;
  // Si c'est l'accueil, on veut une correspondance stricte
  if (href === '/') return currentPath === '/';
  // Sinon, on vérifie si l'URL courante commence par ce lien
  // (ça permet de garder le menu actif même si on est sur /liens/details)
  return currentPath.startsWith(href);
};
---

<aside class="sidebar">
  <div class="brand">
    <div class="brand-logo">L3</div>
    <div>
      <div class="brand-name">Info Hub</div>
      <div class="brand-sub">Licence Informatique</div>
    </div>
  </div>

  <div class="sb-search">
    <span class="ic">⌕</span>
    <input type="text" id="sbSearch" placeholder="Recherche rapide…" autocomplete="off">
    <span class="kbd-hint">⌘K</span>
  </div>

  {sections.map(section => (
    <nav class="nav-section">
      {section.title && <div class="nav-lbl">{section.title}</div>}
      
      {section.items.map(item => {
        // 3. On calcule dynamiquement si ce lien spécifique est actif !
        const active = isItemActive(item.href);
        
        return (
          <a href={item.href || "#"} class={`nav-item ${active ? 'active' : ''}`}>
            {item.icon && <span class="ic">{item.icon}</span>}
            {item.dotColor && <span class="dot" style={`background-color:${item.dotColor}`}></span>}
            
            <span>{item.label}</span>
            
            {item.badge && <span class="badge">{item.badge}</span>}
            {item.count && <span class="n">{item.count}</span>}
          </a>
        )
      })}
    </nav>
  ))}

  <div class="sb-footer">
    <a href="https://github.com/ton-utilisateur/ton-repo" target="_blank" rel="noopener noreferrer" class="promo-card">
      <img src="https://upload.wikimedia.org/wikipedia/commons/1/12/Google_Drive_icon_%282020%29.svg" alt="Google Drive" class="promo-icon-img" />
      <div>
        <div class="promo-name">Licence Informatique Intensive</div>
        <div class="promo-yr">2025–2026</div>
      </div>
    </a>
  </div>
</aside>