---
/**
 * Topbar.astro
 *
 * Top header bar shared across all dashboard pages.
 * Renders the page title, current date, search box, and a CTA button.
 */

interface Props {
  title: string;
  /** Formatted date string, e.g. "Jeudi, 26 mars 2026" */
  date?: string;
  /** Label for the primary action button */
  ctaLabel?: string;
  /** Href for the primary action button */
  ctaHref?: string;
}

const {
  title,
  date      = new Date().toLocaleDateString('fr-FR', { weekday: 'long', day: 'numeric', month: 'long', year: 'numeric' }),
  ctaLabel  = 'Nouveau',
  ctaHref   = '/nouveau',
} = Astro.props;

// Capitalise first letter for display
const dateDisplay = date.charAt(0).toUpperCase() + date.slice(1);
---

<header class="topbar">
  <!-- Page identity -->
  <div class="topbar__left">
    <h1 class="page-title">{title}</h1>
    <p class="page-date">{dateDisplay}</p>
  </div>

  <!-- Actions -->
  <div class="topbar__right">
    <div class="search-box" role="search">
      <span class="search-box__icon" aria-hidden="true">⌕</span>
      <input
        type="search"
        placeholder="Rechercher une fiche…"
        aria-label="Rechercher une fiche"
        class="search-box__input"
      />
    </div>

    <a href={ctaHref} class="btn-cta">
      <span aria-hidden="true">+</span>
      {ctaLabel}
    </a>
  </div>
</header>

<style>
  /* ── Shell ─────────────────────────────────────── */
  .topbar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: var(--space-8);
    gap: var(--space-5);
  }

  /* ── Left: title + date ────────────────────────── */
  .page-title {
    font-family: var(--font-serif);
    font-size: 32px;
    font-weight: 300;
    letter-spacing: -0.01em;
    line-height: 1;
    color: var(--color-text);
  }

  .page-date {
    color: var(--color-text-dim);
    font-size: 13px;
    margin-top: 4px;
  }

  /* ── Right: search + CTA ───────────────────────── */
  .topbar__right {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    flex-shrink: 0;
  }

  /* Search box */
  .search-box {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    padding: 9px 14px;
    width: 240px;
    transition: border-color var(--duration-base);
  }

  .search-box:focus-within {
    border-color: color-mix(in srgb, var(--color-accent) 60%, transparent);
  }

  .search-box__icon {
    color: var(--color-text-dim);
    font-size: 16px;
    flex-shrink: 0;
  }

  .search-box__input {
    background: none;
    border: none;
    outline: none;
    color: var(--color-text);
    font-family: var(--font-sans);
    font-size: 13.5px;
    width: 100%;
  }

  .search-box__input::placeholder {
    color: var(--color-text-faint);
  }

  /* ── CTA button ────────────────────────────────── */
  .btn-cta {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    background: linear-gradient(135deg, #7C9EC9, #B07CC9);
    border-radius: var(--radius-md);
    padding: 9px 18px;
    color: #fff;
    font-family: var(--font-sans);
    font-size: 13.5px;
    font-weight: 500;
    text-decoration: none;
    transition: opacity var(--duration-base);
    white-space: nowrap;
  }

  .btn-cta:hover { opacity: 0.85; }
</style>
