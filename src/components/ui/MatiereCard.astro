---
/**
 * MatiereCard.astro
 *
 * A clickable tile representing one matière.
 * Links to the matière detail page via its slug.
 */

import type { Matiere } from '../../types';

type Props = Matiere;

const { nom, icone, couleur, fiches, exercices, slug } = Astro.props;
---

<a
  href={`/matieres/${slug}`}
  class="matiere-card"
  style={`--card-color: ${couleur}`}
>
  <!-- Icon badge -->
  <div class="matiere-card__icon" aria-hidden="true">
    {icone}
  </div>

  <!-- Text body -->
  <div class="matiere-card__body">
    <span class="matiere-card__name">{nom}</span>
    <div class="matiere-card__counts">
      <span>{fiches} fiches</span>
      <span class="sep" aria-hidden="true">·</span>
      <span>{exercices} exos</span>
    </div>
  </div>

  <!-- Arrow affordance -->
  <span class="matiere-card__arrow" aria-hidden="true">→</span>
</a>

<style>
  .matiere-card {
    display: flex;
    align-items: center;
    gap: 14px;
    padding: 18px;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    text-decoration: none;
    color: var(--color-text);
    transition:
      transform var(--duration-base),
      background var(--duration-base);
  }

  .matiere-card:hover {
    transform: translateY(-2px);
    background: var(--color-surface-2);
  }

  /* ── Icon badge ────────────────────────────────── */
  .matiere-card__icon {
    width: 44px;
    height: 44px;
    border-radius: var(--radius-md);
    border: 1px solid color-mix(in srgb, var(--card-color) 35%, transparent);
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    font-family: var(--font-serif);
    font-size: 22px;
    color: var(--card-color);
  }

  /* ── Body ──────────────────────────────────────── */
  .matiere-card__body {
    flex: 1;
    min-width: 0;
  }

  .matiere-card__name {
    display: block;
    font-size: 14px;
    font-weight: 500;
    margin-bottom: 3px;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .matiere-card__counts {
    font-size: 12px;
    color: var(--color-text-dim);
  }

  .sep {
    margin: 0 4px;
  }

  /* ── Arrow ─────────────────────────────────────── */
  .matiere-card__arrow {
    font-size: 16px;
    color: var(--card-color);
    opacity: 0.5;
    transition: opacity var(--duration-base);
    flex-shrink: 0;
  }

  .matiere-card:hover .matiere-card__arrow {
    opacity: 1;
  }
</style>
