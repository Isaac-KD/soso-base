---
/**
 * StatCard.astro
 *
 * A single KPI tile used in the stats row.
 * The accent colour is applied via a CSS custom property so the
 * parent can compose many cards without duplicating logic.
 */

import type { StatItem } from '../../types';

type Props = StatItem;

const { value, label, icon, accent } = Astro.props;
---

<div class="stat-card" style={`--card-accent: ${accent}`}>
  <span class="stat-card__value">{value}</span>
  <span class="stat-card__label">{label}</span>
  <span class="stat-card__icon" aria-hidden="true">{icon}</span>
</div>

<style>
  .stat-card {
    position: relative;
    overflow: hidden;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    padding: 22px var(--space-5);
    transition:
      transform var(--duration-base),
      border-color var(--duration-base);
  }

  /* Coloured top stripe */
  .stat-card::before {
    content: '';
    position: absolute;
    inset: 0 0 auto 0;
    height: 2px;
    background: var(--card-accent);
  }

  .stat-card:hover {
    transform: translateY(-2px);
    border-color: var(--card-accent);
  }

  /* ── Value ─────────────────────────────────────── */
  .stat-card__value {
    display: block;
    font-family: var(--font-serif);
    font-size: 42px;
    font-weight: 300;
    line-height: 1;
    color: var(--card-accent);
    margin-bottom: 6px;
  }

  /* ── Label ─────────────────────────────────────── */
  .stat-card__label {
    display: block;
    font-size: 12.5px;
    color: var(--color-text-dim);
  }

  /* ── Decorative background icon ────────────────── */
  .stat-card__icon {
    position: absolute;
    right: var(--space-4);
    top: 50%;
    transform: translateY(-50%);
    font-size: 28px;
    color: var(--card-accent);
    opacity: 0.12;
    pointer-events: none;
  }
</style>
