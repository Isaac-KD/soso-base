---
/**
 * DashboardLayout.astro
 *
 * The single HTML shell for every dashboard page.
 * Handles: <head>, font loading, global CSS, noise overlay.
 * Pages simply drop their content into the default <slot />.
 */

interface Props {
  /** <title> for the page */
  title?: string;
  /** Optional meta description */
  description?: string;
}

const {
  title       = 'StudyVault',
  description = 'Mes fiches & exercices',
} = Astro.props;
---

<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={description} />
  <title>{title} — StudyVault</title>

  <!-- Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link
    href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,600;1,300;1,400&family=DM+Mono:wght@300;400;500&family=Outfit:wght@300;400;500;600&display=swap"
    rel="stylesheet"
  />

  <!-- Global styles (tokens + resets) -->
  <style is:global>
    @import '/src/styles/global.css';
  </style>
</head>
<body>
  <!-- Grain texture — purely decorative -->
  <div class="noise-overlay" aria-hidden="true"></div>

  <div class="shell">
    <slot />
  </div>
</body>
</html>

<style>
  .shell {
    display: flex;
    min-height: 100vh;
  }
</style>
