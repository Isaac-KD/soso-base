---
// src/pages/index.astro
// Page d'accueil — StudyVault

const matieres = [
  { nom: "Mathématiques", icone: "∑", couleur: "#7C9EC9", fiches: 12, exercices: 34 },
  { nom: "Physique", icone: "⚛", couleur: "#C98B7C", fiches: 8, exercices: 21 },
  { nom: "Informatique", icone: "</>", couleur: "#7CC9A0", fiches: 15, exercices: 47 },
  { nom: "Chimie", icone: "⚗", couleur: "#C9C37C", fiches: 6, exercices: 18 },
  { nom: "Littérature", icone: "❝", couleur: "#B07CC9", fiches: 9, exercices: 5 },
  { nom: "Histoire", icone: "⧖", couleur: "#C97C9E", fiches: 11, exercices: 8 },
];

const fiches_recentes = [
  { titre: "Intégrales par parties", matiere: "Mathématiques", type: "fiche", date: "24 mars", couleur: "#7C9EC9" },
  { titre: "Les lois de Newton", matiere: "Physique", type: "fiche", date: "22 mars", couleur: "#C98B7C" },
  { titre: "Récursivité en Python", matiere: "Informatique", type: "exercice", date: "20 mars", couleur: "#7CC9A0" },
  { titre: "Liaisons covalentes", matiere: "Chimie", type: "fiche", date: "19 mars", couleur: "#C9C37C" },
  { titre: "La Révolution française", matiere: "Histoire", type: "cours", date: "17 mars", couleur: "#C97C9E" },
];
---

<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>StudyVault — Mes fiches & exercices</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,600;1,300;1,400&family=DM+Mono:wght@300;400;500&family=Outfit:wght@300;400;500;600&display=swap" rel="stylesheet" />
</head>
<body>

<!-- NOISE OVERLAY -->
<div class="noise"></div>

<!-- SIDEBAR NAV -->
<nav class="sidebar">
  <div class="logo">
    <span class="logo-mark">S</span>
    <span class="logo-text">StudyVault</span>
  </div>
  <ul class="nav-links">
    <li><a href="/" class="nav-item active">
      <span class="nav-icon">⌂</span>
      <span>Accueil</span>
    </a></li>
    <li><a href="/fiches" class="nav-item">
      <span class="nav-icon">◫</span>
      <span>Fiches</span>
    </a></li>
    <li><a href="/exercices" class="nav-item">
      <span class="nav-icon">✎</span>
      <span>Exercices</span>
    </a></li>
    <li><a href="/cours" class="nav-item">
      <span class="nav-icon">⊞</span>
      <span>Cours</span>
    </a></li>
    <li><a href="/matieres" class="nav-item">
      <span class="nav-icon">◈</span>
      <span>Matières</span>
    </a></li>
  </ul>
  <div class="nav-bottom">
    <a href="/parametres" class="nav-item">
      <span class="nav-icon">⊙</span>
      <span>Paramètres</span>
    </a>
  </div>
</nav>

<!-- MAIN CONTENT -->
<main class="main">

  <!-- TOPBAR -->
  <header class="topbar">
    <div class="topbar-left">
      <h1 class="page-title">Accueil</h1>
      <p class="page-sub">Jeudi, 26 mars 2026</p>
    </div>
    <div class="topbar-right">
      <div class="search-box">
        <span class="search-icon">⌕</span>
        <input type="text" placeholder="Rechercher une fiche…" />
      </div>
      <button class="btn-new">
        <span>+</span> Nouveau
      </button>
    </div>
  </header>

  <!-- STATS ROW -->
  <section class="stats-row">
    <div class="stat-card" style="--accent: #7C9EC9">
      <span class="stat-num">61</span>
      <span class="stat-label">Fiches de cours</span>
      <span class="stat-icon">◫</span>
    </div>
    <div class="stat-card" style="--accent: #7CC9A0">
      <span class="stat-num">133</span>
      <span class="stat-label">Exercices</span>
      <span class="stat-icon">✎</span>
    </div>
    <div class="stat-card" style="--accent: #C9C37C">
      <span class="stat-num">6</span>
      <span class="stat-label">Matières</span>
      <span class="stat-icon">◈</span>
    </div>
    <div class="stat-card" style="--accent: #C97C9E">
      <span class="stat-num">24</span>
      <span class="stat-label">Cette semaine</span>
      <span class="stat-icon">⧖</span>
    </div>
  </section>

  <!-- TWO COLUMNS -->
  <div class="two-col">

    <!-- Récents -->
    <section class="panel">
      <div class="panel-header">
        <h2 class="panel-title">Récemment ajoutés</h2>
        <a href="/tous" class="panel-link">Voir tout →</a>
      </div>
      <ul class="recents-list">
        {fiches_recentes.map((f) => (
          <li class="recent-item">
            <span class="recent-dot" style={`background: ${f.couleur}`}></span>
            <div class="recent-info">
              <span class="recent-titre">{f.titre}</span>
              <span class="recent-meta">{f.matiere}</span>
            </div>
            <div class="recent-right">
              <span class="badge" style={`--badge-color: ${f.couleur}`}>{f.type}</span>
              <span class="recent-date">{f.date}</span>
            </div>
          </li>
        ))}
      </ul>
    </section>

    <!-- Progression -->
    <section class="panel">
      <div class="panel-header">
        <h2 class="panel-title">Progression</h2>
      </div>
      <div class="progress-list">
        {matieres.slice(0, 4).map((m) => (
          <div class="progress-item">
            <div class="progress-top">
              <span class="progress-nom">{m.nom}</span>
              <span class="progress-count" style={`color: ${m.couleur}`}>{m.fiches} fiches</span>
            </div>
            <div class="progress-bar-bg">
              <div
                class="progress-bar-fill"
                style={`width: ${Math.min(100, (m.fiches / 20) * 100)}%; background: ${m.couleur}`}
              ></div>
            </div>
          </div>
        ))}
      </div>
    </section>

  </div>

  <!-- MATIÈRES GRID -->
  <section class="matieres-section">
    <div class="panel-header">
      <h2 class="panel-title">Mes matières</h2>
      <a href="/matieres" class="panel-link">Gérer →</a>
    </div>
    <div class="matieres-grid">
      {matieres.map((m) => (
        <a href={`/matieres/${m.nom.toLowerCase()}`} class="matiere-card">
          <div class="matiere-icone" style={`color: ${m.couleur}; border-color: ${m.couleur}22`}>
            {m.icone}
          </div>
          <div class="matiere-body">
            <span class="matiere-nom">{m.nom}</span>
            <div class="matiere-counts">
              <span>{m.fiches} fiches</span>
              <span class="sep">·</span>
              <span>{m.exercices} exos</span>
            </div>
          </div>
          <span class="matiere-arrow" style={`color: ${m.couleur}`}>→</span>
        </a>
      ))}
    </div>
  </section>

</main>

<style>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  :root {
    --bg:        #0f0f13;
    --surface:   #16161d;
    --surface2:  #1d1d26;
    --border:    #2a2a38;
    --text:      #e8e4da;
    --text-dim:  #7a7690;
    --text-faint:#3d3a50;
    --sidebar-w: 220px;
    --radius:    12px;
  }

  html, body { height: 100%; }

  body {
    font-family: 'Outfit', sans-serif;
    background: var(--bg);
    color: var(--text);
    display: flex;
    min-height: 100vh;
    overflow-x: hidden;
  }

  /* NOISE */
  .noise {
    position: fixed; inset: 0; pointer-events: none; z-index: 999;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)' opacity='0.04'/%3E%3C/svg%3E");
    opacity: 0.35;
  }

  /* SIDEBAR */
  .sidebar {
    width: var(--sidebar-w);
    min-height: 100vh;
    background: var(--surface);
    border-right: 1px solid var(--border);
    display: flex;
    flex-direction: column;
    padding: 28px 16px;
    position: sticky;
    top: 0;
    height: 100vh;
    flex-shrink: 0;
  }

  .logo {
    display: flex; align-items: center; gap: 10px;
    padding: 0 8px 28px;
    border-bottom: 1px solid var(--border);
    margin-bottom: 20px;
  }
  .logo-mark {
    width: 34px; height: 34px;
    background: linear-gradient(135deg, #7C9EC9, #B07CC9);
    border-radius: 9px;
    display: flex; align-items: center; justify-content: center;
    font-family: 'Cormorant Garamond', serif;
    font-weight: 600; font-size: 18px; color: #fff;
    flex-shrink: 0;
  }
  .logo-text {
    font-family: 'Cormorant Garamond', serif;
    font-size: 17px; font-weight: 600; letter-spacing: 0.02em;
  }

  .nav-links { list-style: none; display: flex; flex-direction: column; gap: 2px; flex: 1; }
  .nav-item {
    display: flex; align-items: center; gap: 10px;
    padding: 9px 12px; border-radius: 8px;
    color: var(--text-dim); font-size: 14px;
    text-decoration: none; transition: all 0.18s; font-weight: 400;
  }
  .nav-item:hover { background: var(--surface2); color: var(--text); }
  .nav-item.active { background: var(--surface2); color: var(--text); font-weight: 500; }
  .nav-icon { font-size: 15px; width: 18px; text-align: center; }
  .nav-bottom { border-top: 1px solid var(--border); padding-top: 16px; margin-top: 8px; }

  /* MAIN */
  .main {
    flex: 1; padding: 32px 36px;
    max-width: calc(100vw - var(--sidebar-w));
    overflow-y: auto;
  }

  /* TOPBAR */
  .topbar {
    display: flex; align-items: center; justify-content: space-between;
    margin-bottom: 32px;
  }
  .page-title {
    font-family: 'Cormorant Garamond', serif;
    font-size: 32px; font-weight: 300; letter-spacing: -0.01em;
  }
  .page-sub { color: var(--text-dim); font-size: 13px; margin-top: 2px; }
  .topbar-right { display: flex; gap: 12px; align-items: center; }

  .search-box {
    display: flex; align-items: center; gap: 8px;
    background: var(--surface); border: 1px solid var(--border);
    border-radius: 9px; padding: 9px 14px; width: 240px;
  }
  .search-icon { color: var(--text-dim); font-size: 16px; }
  .search-box input {
    background: none; border: none; outline: none;
    color: var(--text); font-family: 'Outfit', sans-serif; font-size: 13.5px; width: 100%;
  }
  .search-box input::placeholder { color: var(--text-faint); }

  .btn-new {
    display: flex; align-items: center; gap: 6px;
    background: linear-gradient(135deg, #7C9EC9, #B07CC9);
    border: none; border-radius: 9px;
    padding: 9px 18px; color: #fff;
    font-family: 'Outfit', sans-serif; font-size: 13.5px; font-weight: 500;
    cursor: pointer; transition: opacity 0.18s;
  }
  .btn-new:hover { opacity: 0.85; }

  /* STATS */
  .stats-row {
    display: grid; grid-template-columns: repeat(4, 1fr);
    gap: 16px; margin-bottom: 28px;
  }
  .stat-card {
    background: var(--surface); border: 1px solid var(--border);
    border-radius: var(--radius); padding: 22px 20px;
    position: relative; overflow: hidden;
    transition: transform 0.18s, border-color 0.18s;
  }
  .stat-card:hover { transform: translateY(-2px); border-color: var(--accent); }
  .stat-card::before {
    content: ''; position: absolute; top: 0; left: 0; right: 0; height: 2px;
    background: var(--accent);
  }
  .stat-num {
    display: block;
    font-family: 'Cormorant Garamond', serif;
    font-size: 42px; font-weight: 300; line-height: 1;
    color: var(--accent); margin-bottom: 6px;
  }
  .stat-label { display: block; font-size: 12.5px; color: var(--text-dim); }
  .stat-icon {
    position: absolute; right: 16px; top: 50%; transform: translateY(-50%);
    font-size: 28px; color: var(--accent); opacity: 0.12;
  }

  /* TWO-COL */
  .two-col { display: grid; grid-template-columns: 1fr 1fr; gap: 20px; margin-bottom: 28px; }

  /* PANEL */
  .panel {
    background: var(--surface); border: 1px solid var(--border);
    border-radius: var(--radius); padding: 24px;
  }
  .panel-header {
    display: flex; align-items: center; justify-content: space-between;
    margin-bottom: 20px;
  }
  .panel-title {
    font-family: 'Cormorant Garamond', serif;
    font-size: 18px; font-weight: 400; letter-spacing: 0.01em;
  }
  .panel-link { font-size: 12px; color: var(--text-dim); text-decoration: none; transition: color 0.15s; }
  .panel-link:hover { color: var(--text); }

  /* RECENTS */
  .recents-list { list-style: none; display: flex; flex-direction: column; gap: 2px; }
  .recent-item {
    display: flex; align-items: center; gap: 12px;
    padding: 10px; border-radius: 8px;
    transition: background 0.15s; cursor: pointer;
  }
  .recent-item:hover { background: var(--surface2); }
  .recent-dot { width: 8px; height: 8px; border-radius: 50%; flex-shrink: 0; }
  .recent-info { flex: 1; min-width: 0; }
  .recent-titre { display: block; font-size: 13.5px; font-weight: 500; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
  .recent-meta { display: block; font-size: 11.5px; color: var(--text-dim); margin-top: 1px; }
  .recent-right { display: flex; flex-direction: column; align-items: flex-end; gap: 3px; flex-shrink: 0; }
  .badge {
    font-family: 'DM Mono', monospace;
    font-size: 10px; padding: 2px 7px;
    border: 1px solid var(--badge-color);
    color: var(--badge-color); border-radius: 4px; opacity: 0.9;
  }
  .recent-date { font-size: 11px; color: var(--text-faint); }

  /* PROGRESS */
  .progress-list { display: flex; flex-direction: column; gap: 18px; }
  .progress-top { display: flex; justify-content: space-between; margin-bottom: 7px; font-size: 13px; }
  .progress-nom { color: var(--text); }
  .progress-count { font-family: 'DM Mono', monospace; font-size: 12px; }
  .progress-bar-bg { height: 4px; background: var(--border); border-radius: 99px; overflow: hidden; }
  .progress-bar-fill { height: 100%; border-radius: 99px; transition: width 0.6s cubic-bezier(.16,1,.3,1); }

  /* MATIÈRES */
  .matieres-section { }
  .matieres-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 14px; }
  .matiere-card {
    background: var(--surface); border: 1px solid var(--border);
    border-radius: var(--radius); padding: 18px;
    display: flex; align-items: center; gap: 14px;
    text-decoration: none; color: var(--text);
    transition: transform 0.18s, background 0.18s;
    cursor: pointer;
  }
  .matiere-card:hover { transform: translateY(-2px); background: var(--surface2); }
  .matiere-icone {
    font-family: 'Cormorant Garamond', serif;
    font-size: 22px; width: 44px; height: 44px;
    border: 1px solid; border-radius: 10px;
    display: flex; align-items: center; justify-content: center; flex-shrink: 0;
  }
  .matiere-body { flex: 1; }
  .matiere-nom { display: block; font-size: 14px; font-weight: 500; margin-bottom: 3px; }
  .matiere-counts { font-size: 12px; color: var(--text-dim); }
  .sep { margin: 0 4px; }
  .matiere-arrow { font-size: 16px; margin-left: auto; opacity: 0.5; transition: opacity 0.15s; }
  .matiere-card:hover .matiere-arrow { opacity: 1; }

  /* ANIMATIONS */
  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(14px); }
    to   { opacity: 1; transform: translateY(0); }
  }
  .stats-row      { animation: fadeUp .45s ease both; }
  .two-col        { animation: fadeUp .45s .1s ease both; }
  .matieres-section { animation: fadeUp .45s .2s ease both; }

  ::-webkit-scrollbar { width: 6px; }
  ::-webkit-scrollbar-track { background: var(--bg); }
  ::-webkit-scrollbar-thumb { background: var(--border); border-radius: 99px; }
</style>

</body>
</html>