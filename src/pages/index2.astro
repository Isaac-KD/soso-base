---
// index.astro — Page d'accueil du site de fiches de cours
const matieres = [
  { nom: "Mathématiques", icone: "∑", couleur: "#E8C547", count: 12, slug: "maths" },
  { nom: "Physique-Chimie", icone: "⚛", couleur: "#7EC8E3", count: 8, slug: "physique" },
  { nom: "Informatique", icone: "</>", couleur: "#A8E6A3", count: 15, slug: "info" },
  { nom: "Histoire", icone: "⌛", couleur: "#F4A261", count: 6, slug: "histoire" },
  { nom: "Philosophie", icone: "∞", couleur: "#D4A5F5", count: 4, slug: "philo" },
  { nom: "Langues", icone: "Aa", couleur: "#FF8FAB", count: 9, slug: "langues" },
];

const ficheRecentes = [
  { titre: "Dérivées et primitives", matiere: "Mathématiques", date: "24 mars 2026", type: "Cours" },
  { titre: "Lois de Newton", matiere: "Physique-Chimie", date: "22 mars 2026", type: "Exercice" },
  { titre: "Structures de données", matiere: "Informatique", date: "20 mars 2026", type: "Résumé" },
  { titre: "La Révolution française", matiere: "Histoire", date: "18 mars 2026", type: "Fiche" },
];
---

<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Mes Fiches — Base de Connaissances</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,700;0,900;1,400&family=JetBrains+Mono:wght@300;400;500&family=Lora:wght@400;500&display=swap" rel="stylesheet" />
  <style>
    :root {
      --bg: #0E0E10;
      --bg-2: #16161A;
      --bg-3: #1E1E24;
      --border: rgba(255,255,255,0.07);
      --text: #E8E4D9;
      --text-dim: #7A7671;
      --accent: #E8C547;
      --accent-dim: rgba(232,197,71,0.12);
      --serif: 'Playfair Display', Georgia, serif;
      --mono: 'JetBrains Mono', monospace;
      --body: 'Lora', Georgia, serif;
    }

    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    html { scroll-behavior: smooth; }

    body {
      background: var(--bg);
      color: var(--text);
      font-family: var(--body);
      min-height: 100vh;
      overflow-x: hidden;
    }

    /* ── Texture de fond ── */
    body::before {
      content: '';
      position: fixed;
      inset: 0;
      background-image:
        repeating-linear-gradient(
          0deg,
          transparent,
          transparent 28px,
          rgba(255,255,255,0.018) 28px,
          rgba(255,255,255,0.018) 29px
        );
      pointer-events: none;
      z-index: 0;
    }

    /* ── Navigation ── */
    nav {
      position: sticky;
      top: 0;
      z-index: 100;
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 1.1rem 3rem;
      background: rgba(14,14,16,0.85);
      backdrop-filter: blur(16px);
      border-bottom: 1px solid var(--border);
    }

    .nav-logo {
      font-family: var(--serif);
      font-size: 1.25rem;
      font-weight: 700;
      color: var(--text);
      text-decoration: none;
      letter-spacing: -0.01em;
    }

    .nav-logo span { color: var(--accent); }

    .nav-links {
      display: flex;
      gap: 2.5rem;
      list-style: none;
    }

    .nav-links a {
      font-family: var(--mono);
      font-size: 0.7rem;
      font-weight: 400;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      color: var(--text-dim);
      text-decoration: none;
      transition: color 0.2s;
    }

    .nav-links a:hover { color: var(--text); }

    .nav-btn {
      font-family: var(--mono);
      font-size: 0.7rem;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      padding: 0.55rem 1.2rem;
      background: var(--accent);
      color: #0E0E10;
      border: none;
      cursor: pointer;
      text-decoration: none;
      transition: opacity 0.2s;
    }

    .nav-btn:hover { opacity: 0.85; }

    /* ── Hero ── */
    .hero {
      position: relative;
      z-index: 1;
      padding: 7rem 3rem 5rem;
      max-width: 1200px;
      margin: 0 auto;
    }

    .hero-label {
      font-family: var(--mono);
      font-size: 0.65rem;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: var(--accent);
      margin-bottom: 1.5rem;
      display: flex;
      align-items: center;
      gap: 0.75rem;
    }

    .hero-label::before {
      content: '';
      display: block;
      width: 2rem;
      height: 1px;
      background: var(--accent);
    }

    .hero-title {
      font-family: var(--serif);
      font-size: clamp(3.5rem, 7vw, 6.5rem);
      font-weight: 900;
      line-height: 0.95;
      letter-spacing: -0.03em;
      margin-bottom: 0.2em;
      animation: fadeUp 0.8s ease both;
    }

    .hero-title em {
      font-style: italic;
      color: var(--accent);
    }

    .hero-sub {
      font-family: var(--body);
      font-size: 1.1rem;
      color: var(--text-dim);
      max-width: 480px;
      line-height: 1.7;
      margin-top: 1.5rem;
      animation: fadeUp 0.8s 0.15s ease both;
    }

    .hero-actions {
      display: flex;
      gap: 1rem;
      margin-top: 2.5rem;
      animation: fadeUp 0.8s 0.3s ease both;
    }

    .btn-primary {
      font-family: var(--mono);
      font-size: 0.72rem;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      padding: 0.9rem 2rem;
      background: var(--accent);
      color: #0E0E10;
      border: none;
      cursor: pointer;
      text-decoration: none;
      transition: transform 0.2s, opacity 0.2s;
    }

    .btn-primary:hover { transform: translateY(-2px); opacity: 0.9; }

    .btn-ghost {
      font-family: var(--mono);
      font-size: 0.72rem;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      padding: 0.9rem 2rem;
      background: transparent;
      color: var(--text-dim);
      border: 1px solid var(--border);
      cursor: pointer;
      text-decoration: none;
      transition: color 0.2s, border-color 0.2s;
    }

    .btn-ghost:hover { color: var(--text); border-color: rgba(255,255,255,0.2); }

    .hero-stats {
      display: flex;
      gap: 3rem;
      margin-top: 4rem;
      padding-top: 2.5rem;
      border-top: 1px solid var(--border);
      animation: fadeUp 0.8s 0.45s ease both;
    }

    .stat-num {
      font-family: var(--serif);
      font-size: 2.2rem;
      font-weight: 700;
      color: var(--text);
      line-height: 1;
    }

    .stat-label {
      font-family: var(--mono);
      font-size: 0.62rem;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: var(--text-dim);
      margin-top: 0.3rem;
    }

    /* ── Séparateur ── */
    .section-header {
      display: flex;
      align-items: baseline;
      justify-content: space-between;
      margin-bottom: 2rem;
    }

    .section-title {
      font-family: var(--serif);
      font-size: 1.8rem;
      font-weight: 700;
      color: var(--text);
    }

    .section-link {
      font-family: var(--mono);
      font-size: 0.65rem;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      color: var(--accent);
      text-decoration: none;
    }

    .section-link:hover { text-decoration: underline; }

    /* ── Grille matières ── */
    .matieres-section {
      position: relative;
      z-index: 1;
      max-width: 1200px;
      margin: 0 auto;
      padding: 2rem 3rem 5rem;
    }

    .matieres-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 1px;
      background: var(--border);
      border: 1px solid var(--border);
    }

    .matiere-card {
      background: var(--bg-2);
      padding: 2rem 1.75rem;
      text-decoration: none;
      display: flex;
      flex-direction: column;
      gap: 1rem;
      transition: background 0.25s;
      cursor: pointer;
      position: relative;
      overflow: hidden;
    }

    .matiere-card::after {
      content: '';
      position: absolute;
      bottom: 0;
      left: 0;
      right: 0;
      height: 2px;
      background: var(--card-color, var(--accent));
      transform: scaleX(0);
      transform-origin: left;
      transition: transform 0.3s ease;
    }

    .matiere-card:hover { background: var(--bg-3); }
    .matiere-card:hover::after { transform: scaleX(1); }

    .matiere-icone {
      font-family: var(--mono);
      font-size: 1.6rem;
      color: var(--card-color, var(--accent));
      line-height: 1;
    }

    .matiere-nom {
      font-family: var(--serif);
      font-size: 1.15rem;
      font-weight: 700;
      color: var(--text);
    }

    .matiere-count {
      font-family: var(--mono);
      font-size: 0.65rem;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      color: var(--text-dim);
      margin-top: auto;
    }

    /* ── Fiches récentes ── */
    .recentes-section {
      position: relative;
      z-index: 1;
      max-width: 1200px;
      margin: 0 auto;
      padding: 0 3rem 6rem;
    }

    .fiches-list {
      display: flex;
      flex-direction: column;
      gap: 1px;
      background: var(--border);
      border: 1px solid var(--border);
    }

    .fiche-row {
      background: var(--bg-2);
      padding: 1.4rem 1.75rem;
      display: grid;
      grid-template-columns: 1fr auto auto auto;
      align-items: center;
      gap: 2rem;
      text-decoration: none;
      transition: background 0.2s;
      cursor: pointer;
    }

    .fiche-row:hover { background: var(--bg-3); }

    .fiche-titre {
      font-family: var(--serif);
      font-size: 1.05rem;
      color: var(--text);
    }

    .fiche-matiere {
      font-family: var(--mono);
      font-size: 0.65rem;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      color: var(--text-dim);
    }

    .fiche-type {
      font-family: var(--mono);
      font-size: 0.6rem;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      padding: 0.3rem 0.75rem;
      background: var(--accent-dim);
      color: var(--accent);
      border: 1px solid rgba(232,197,71,0.2);
    }

    .fiche-date {
      font-family: var(--mono);
      font-size: 0.65rem;
      color: var(--text-dim);
      white-space: nowrap;
    }

    /* ── Barre de recherche ── */
    .search-section {
      position: relative;
      z-index: 1;
      max-width: 1200px;
      margin: 0 auto;
      padding: 0 3rem 5rem;
    }

    .search-wrap {
      position: relative;
      max-width: 600px;
    }

    .search-icon {
      position: absolute;
      left: 1.25rem;
      top: 50%;
      transform: translateY(-50%);
      font-family: var(--mono);
      font-size: 0.75rem;
      color: var(--text-dim);
      pointer-events: none;
    }

    .search-input {
      width: 100%;
      background: var(--bg-2);
      border: 1px solid var(--border);
      color: var(--text);
      font-family: var(--mono);
      font-size: 0.85rem;
      padding: 1rem 1.25rem 1rem 3rem;
      outline: none;
      transition: border-color 0.2s;
    }

    .search-input::placeholder { color: var(--text-dim); }
    .search-input:focus { border-color: rgba(232,197,71,0.4); }

    /* ── Footer ── */
    footer {
      position: relative;
      z-index: 1;
      border-top: 1px solid var(--border);
      padding: 2rem 3rem;
      display: flex;
      justify-content: space-between;
      align-items: center;
      max-width: 100%;
    }

    .footer-text {
      font-family: var(--mono);
      font-size: 0.6rem;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      color: var(--text-dim);
    }

    /* ── Animations ── */
    @keyframes fadeUp {
      from { opacity: 0; transform: translateY(24px); }
      to   { opacity: 1; transform: translateY(0); }
    }

    /* ── Responsive ── */
    @media (max-width: 900px) {
      nav { padding: 1rem 1.5rem; }
      .nav-links { display: none; }
      .hero { padding: 5rem 1.5rem 4rem; }
      .hero-stats { gap: 2rem; flex-wrap: wrap; }
      .matieres-section, .recentes-section, .search-section { padding-inline: 1.5rem; }
      .matieres-grid { grid-template-columns: repeat(2, 1fr); }
      .fiche-row { grid-template-columns: 1fr auto; }
      .fiche-matiere, .fiche-date { display: none; }
    }

    @media (max-width: 560px) {
      .matieres-grid { grid-template-columns: 1fr; }
    }
  </style>
</head>
<body>

  <!-- Navigation -->
  <nav>
    <a class="nav-logo" href="/">Mes<span>Fiches</span></a>
    <ul class="nav-links">
      <li><a href="/matieres">Matières</a></li>
      <li><a href="/exercices">Exercices</a></li>
      <li><a href="/recherche">Recherche</a></li>
    </ul>
    <a class="nav-btn" href="/nouvelle-fiche">+ Nouvelle fiche</a>
  </nav>

  <!-- Hero -->
  <section class="hero">
    <p class="hero-label">Base de connaissances personnelle</p>
    <h1 class="hero-title">
      Toutes tes<br/>
      <em>connaissances,</em><br/>
      en ordre.
    </h1>
    <p class="hero-sub">
      Cours, exercices, résumés et fiches de révision — organisés par matière,
      accessibles en un instant.
    </p>
    <div class="hero-actions">
      <a class="btn-primary" href="/matieres">Parcourir les matières</a>
      <a class="btn-ghost" href="/nouvelle-fiche">Créer une fiche</a>
    </div>
    <div class="hero-stats">
      <div>
        <div class="stat-num">54</div>
        <div class="stat-label">Fiches au total</div>
      </div>
      <div>
        <div class="stat-num">6</div>
        <div class="stat-label">Matières</div>
      </div>
      <div>
        <div class="stat-num">12</div>
        <div class="stat-label">Exercices résolus</div>
      </div>
    </div>
  </section>

  <!-- Recherche rapide -->
  <section class="search-section">
    <div class="search-wrap">
      <span class="search-icon">⌕</span>
      <input
        class="search-input"
        type="text"
        placeholder="Rechercher une fiche, un cours, un exercice…"
      />
    </div>
  </section>

  <!-- Grille des matières -->
  <section class="matieres-section">
    <div class="section-header">
      <h2 class="section-title">Matières</h2>
      <a class="section-link" href="/matieres">Toutes les matières →</a>
    </div>
    <div class="matieres-grid">
      {matieres.map((m) => (
        <a
          class="matiere-card"
          href={`/matieres/${m.slug}`}
          style={`--card-color: ${m.couleur}`}
        >
          <span class="matiere-icone">{m.icone}</span>
          <span class="matiere-nom">{m.nom}</span>
          <span class="matiere-count">{m.count} fiche{m.count > 1 ? 's' : ''}</span>
        </a>
      ))}
    </div>
  </section>

  <!-- Fiches récentes -->
  <section class="recentes-section">
    <div class="section-header">
      <h2 class="section-title">Ajoutées récemment</h2>
      <a class="section-link" href="/fiches">Toutes les fiches →</a>
    </div>
    <div class="fiches-list">
      {ficheRecentes.map((f) => (
        <a class="fiche-row" href="#">
          <span class="fiche-titre">{f.titre}</span>
          <span class="fiche-matiere">{f.matiere}</span>
          <span class="fiche-type">{f.type}</span>
          <span class="fiche-date">{f.date}</span>
        </a>
      ))}
    </div>
  </section>

  <!-- Footer -->
  <footer>
    <span class="footer-text">MesFiches — Base de connaissances personnelle</span>
    <span class="footer-text">© 2026</span>
  </footer>

</body>
</html>