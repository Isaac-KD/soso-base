---
// src/pages/index.astro
// Page d'accueil — StudyVault

const matieres = [
  { nom: "Mathématiques", icone: "∑", couleur: "#7C9EC9", fiches: 12, exercices: 34 },
  { nom: "Physique", icone: "⚛", couleur: "#C98B7C", fiches: 8, exercices: 21 },
  { nom: "Informatique", icone: "</>", couleur: "#7CC9A0", fiches: 15, exercices: 47 },
  { nom: "Chimie", icone: "⚗", couleur: "#C9C37C", fiches: 6, exercices: 18 },
  { nom: "Littérature", icone: "❝", couleur: "#B07CC9", fiches: 9, exercices: 5 },
  { nom: "Histoire", icone: "⧖", couleur: "#C97C9E", fiches: 11, exercices: 8 },
];
const fiches_recentes = [
  { titre: "Intégrales par parties", matiere: "Mathématiques", type: "fiche", date: "24 mars", couleur: "#7C9EC9" },
  { titre: "Les lois de Newton", matiere: "Physique", type: "fiche", date: "22 mars", couleur: "#C98B7C" },
  { titre: "Récursivité en Python", matiere: "Informatique", type: "exercice", date: "20 mars", couleur: "#7CC9A0" },
  { titre: "Liaisons covalentes", matiere: "Chimie", type: "fiche", date: "19 mars", couleur: "#C9C37C" },
  { titre: "La Révolution française", matiere: "Histoire", type: "cours", date: "17 mars", couleur: "#C97C9E" },
];
---

<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>StudyVault — Mes fiches & exercices</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,600;1,300;1,400&family=DM+Mono:wght@300;400;500&family=Outfit:wght@300;400;500;600&display=swap" rel="stylesheet" />
</head>
<body>

<div class="noise"></div>

<nav class="sidebar">
  <div class="logo">
    <span class="logo-mark">S</span>
    <span class="logo-text">StudyVault</span>
  </div>
  <ul class="nav-links">
    <li><a href="/" class="nav-item active">
      <span class="nav-icon">⌂</span>
      <span>Accueil</span>
    </a></li>
    <li><a href="/fiches" class="nav-item">
      <span class="nav-icon">◫</span>
      <span>Fiches</span>
    </a></li>
    <li><a href="/exercices" class="nav-item">
      <span class="nav-icon">✎</span>
      <span>Exercices</span>
    </a></li>
    <li><a href="/cours" class="nav-item">
      <span class="nav-icon">⊞</span>
      <span>Cours</span>
    </a></li>
    <li><a href="/matieres" class="nav-item">
      <span class="nav-icon">◈</span>
      <span>Matières</span>
    </a></li>
  </ul>
  <div class="nav-bottom">
    <a href="/parametres" class="nav-item">
      <span class="nav-icon">⊙</span>
      <span>Paramètres</span>
    </a>
  </div>
</nav>

<main class="main">

  <header class="topbar">
    <div class="topbar-left">
      <h1 class="page-title">Accueil</h1>
      <p class="page-sub">Jeudi, 26 mars 2026</p>
    </div>
    <div class="topbar-right">
      <div class="search-box">
        <span class="search-icon">⌕</span>
        <input type="text" placeholder="Rechercher une fiche…" />
      </div>
      <button class="btn-new">
        <span>+</span> 
        Nouveau
      </button>
    </div>
  </header>

  <section class="stats-row">
    <div class="stat-card" style="--accent: #7C9EC9">
      <span class="stat-num">61</span>
      <span class="stat-label">Fiches de cours</span>
      <span class="stat-icon">◫</span>
    </div>
    <div class="stat-card" style="--accent: #7CC9A0">
      <span class="stat-num">133</span>
      <span class="stat-label">Exercices</span>
      <span class="stat-icon">✎</span>
    </div>
    <div class="stat-card" style="--accent: #C9C37C">
      <span class="stat-num">6</span>
      <span class="stat-label">Matières</span>
      <span class="stat-icon">◈</span>
    </div>
    <div class="stat-card" style="--accent: #C97C9E">
      <span class="stat-num">24</span>
      <span class="stat-label">Cette semaine</span>
      <span class="stat-icon">⧖</span>
    </div>
  </section>

  <div class="two-col">

    <section class="panel">
      <div class="panel-header">
        <h2 class="panel-title">Graphe des connaissances</h2>
        <a href="/tous" class="panel-link">Voir tout →</a>
      </div>
      <div id="graph-container" style="width: 100%; height: 300px; background: var(--surface2); border-radius: 8px; overflow: hidden; cursor: grab;"></div>
    </section>

    <section class="panel">
      <div class="panel-header">
        <h2 class="panel-title">Progression</h2>
      </div>
      <div class="progress-list">
        {matieres.slice(0, 4).map((m) => (
          <div class="progress-item">
            <div class="progress-top">
              <span class="progress-nom">{m.nom}</span>
              <span class="progress-count" style={`color: ${m.couleur}`}>{m.fiches} fiches</span>
            </div>
            <div class="progress-bar-bg">
              <div
                class="progress-bar-fill"
                style={`width: ${Math.min(100, (m.fiches / 20) * 100)}%; background: ${m.couleur}`}
              ></div>
            </div>
          </div>
        ))}
      </div>
    </section>

  </div>

  <section class="matieres-section">
    <div class="panel-header">
      <h2 class="panel-title">Mes matières</h2>
      <a href="/matieres" class="panel-link">Gérer →</a>
    </div>
    <div class="matieres-grid">
      {matieres.map((m) => (
        <a href={`/matieres/${m.nom.toLowerCase()}`} class="matiere-card">
          <div class="matiere-icone" style={`color: ${m.couleur}; border-color: ${m.couleur}22`}>
            {m.icone}
          </div>
          <div class="matiere-body">
            <span class="matiere-nom">{m.nom}</span>
            <div class="matiere-counts">
              <span>{m.fiches} fiches</span>
              <span class="sep">·</span>
              <span>{m.exercices} exos</span>
            </div>
          </div>
          <span class="matiere-arrow" style={`color: ${m.couleur}`}>→</span>
        </a>
      ))}
    </div>
  </section>

</main>

<style>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  :root {
    --bg:        #0f0f13;
    --surface:   #16161d;
    --surface2:  #1d1d26;
    --border:    #2a2a38;
    --text:      #e8e4da;
    --text-dim:  #7a7690;
    --text-faint:#3d3a50;
    --sidebar-w: 220px;
    --radius:    12px;
  }

  html, body { height: 100%; }

  body {
    font-family: 'Outfit', sans-serif;
    background: var(--bg);
    color: var(--text);
    display: flex;
    min-height: 100vh;
    overflow-x: hidden;
  }

  /* NOISE */
  .noise {
    position: fixed; inset: 0; pointer-events: none; z-index: 999;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)' opacity='0.04'/%3E%3C/svg%3E");
    opacity: 0.35;
  }

  /* SIDEBAR */
  .sidebar {
    width: var(--sidebar-w);
    min-height: 100vh;
    background: var(--surface);
    border-right: 1px solid var(--border);
    display: flex;
    flex-direction: column;
    padding: 28px 16px;
    position: sticky;
    top: 0;
    height: 100vh;
    flex-shrink: 0;
  }

  .logo {
    display: flex; align-items: center; gap: 10px;
    padding: 0 8px 28px;
    border-bottom: 1px solid var(--border);
    margin-bottom: 20px;
  }
  .logo-mark {
    width: 34px; height: 34px;
    background: linear-gradient(135deg, #7C9EC9, #B07CC9);
    border-radius: 9px;
    display: flex; align-items: center; justify-content: center;
    font-family: 'Cormorant Garamond', serif;
    font-weight: 600; font-size: 18px;
    color: #fff;
    flex-shrink: 0;
  }
  .logo-text {
    font-family: 'Cormorant Garamond', serif;
    font-size: 17px; font-weight: 600;
    letter-spacing: 0.02em;
  }

  .nav-links { list-style: none; display: flex; flex-direction: column; gap: 2px; flex: 1; }
  .nav-item {
    display: flex; align-items: center; gap: 10px;
    padding: 9px 12px; border-radius: 8px;
    color: var(--text-dim);
    font-size: 14px;
    text-decoration: none; transition: all 0.18s; font-weight: 400;
  }
  .nav-item:hover { background: var(--surface2); color: var(--text); }
  .nav-item.active { background: var(--surface2); color: var(--text); font-weight: 500; }
  .nav-icon { font-size: 15px; width: 18px; text-align: center; }
  .nav-bottom { border-top: 1px solid var(--border); padding-top: 16px; margin-top: 8px; }

  /* MAIN */
  .main {
    flex: 1; padding: 32px 36px;
    max-width: calc(100vw - var(--sidebar-w));
    overflow-y: auto;
  }

  /* TOPBAR */
  .topbar {
    display: flex; align-items: center; justify-content: space-between;
    margin-bottom: 32px;
  }
  .page-title {
    font-family: 'Cormorant Garamond', serif;
    font-size: 32px; font-weight: 300; letter-spacing: -0.01em;
  }
  .page-sub { color: var(--text-dim); font-size: 13px; margin-top: 2px; }
  .topbar-right { display: flex; gap: 12px; align-items: center; }

  .search-box {
    display: flex; align-items: center; gap: 8px;
    background: var(--surface); border: 1px solid var(--border);
    border-radius: 9px; padding: 9px 14px; width: 240px;
  }
  .search-icon { color: var(--text-dim); font-size: 16px; }
  .search-box input {
    background: none; border: none; outline: none;
    color: var(--text); font-family: 'Outfit', sans-serif;
    font-size: 13.5px; width: 100%;
  }
  .search-box input::placeholder { color: var(--text-faint); }

  .btn-new {
    display: flex;
    align-items: center; gap: 6px;
    background: linear-gradient(135deg, #7C9EC9, #B07CC9);
    border: none; border-radius: 9px;
    padding: 9px 18px; color: #fff;
    font-family: 'Outfit', sans-serif;
    font-size: 13.5px; font-weight: 500;
    cursor: pointer; transition: opacity 0.18s;
  }
  .btn-new:hover { opacity: 0.85; }

  /* STATS */
  .stats-row {
    display: grid; grid-template-columns: repeat(4, 1fr);
    gap: 16px; margin-bottom: 28px;
  }
  .stat-card {
    background: var(--surface); border: 1px solid var(--border);
    border-radius: var(--radius); padding: 22px 20px;
    position: relative;
    overflow: hidden;
    transition: transform 0.18s, border-color 0.18s;
  }
  .stat-card:hover { transform: translateY(-2px); border-color: var(--accent); }
  .stat-card::before {
    content: ''; position: absolute; top: 0; left: 0; right: 0; height: 2px;
    background: var(--accent);
  }
  .stat-num {
    display: block;
    font-family: 'Cormorant Garamond', serif;
    font-size: 42px; font-weight: 300;
    line-height: 1;
    color: var(--accent); margin-bottom: 6px;
  }
  .stat-label { display: block; font-size: 12.5px; color: var(--text-dim); }
  .stat-icon {
    position: absolute; right: 16px; top: 50%; transform: translateY(-50%);
    font-size: 28px; color: var(--accent);
    opacity: 0.12;
  }

  /* TWO-COL */
  .two-col { display: grid; grid-template-columns: 1fr 1fr; gap: 20px; margin-bottom: 28px; }

  /* PANEL */
  .panel {
    background: var(--surface); border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 24px;
  }
  .panel-header {
    display: flex; align-items: center; justify-content: space-between;
    margin-bottom: 20px;
  }
  .panel-title {
    font-family: 'Cormorant Garamond', serif;
    font-size: 18px; font-weight: 400; letter-spacing: 0.01em;
  }
  .panel-link { font-size: 12px; color: var(--text-dim); text-decoration: none; transition: color 0.15s; }
  .panel-link:hover { color: var(--text); }

  /* PROGRESS */
  .progress-list { display: flex; flex-direction: column; gap: 18px; }
  .progress-top { display: flex;
    justify-content: space-between; margin-bottom: 7px; font-size: 13px; }
  .progress-nom { color: var(--text); }
  .progress-count { font-family: 'DM Mono', monospace;
    font-size: 12px; }
  .progress-bar-bg { height: 4px; background: var(--border); border-radius: 99px; overflow: hidden; }
  .progress-bar-fill { height: 100%;
    border-radius: 99px; transition: width 0.6s cubic-bezier(.16,1,.3,1); }

  /* MATIÈRES */
  .matieres-section { }
  .matieres-grid { display: grid;
    grid-template-columns: repeat(3, 1fr); gap: 14px; }
  .matiere-card {
    background: var(--surface); border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 18px;
    display: flex; align-items: center; gap: 14px;
    text-decoration: none; color: var(--text);
    transition: transform 0.18s, background 0.18s;
    cursor: pointer;
  }
  .matiere-card:hover { transform: translateY(-2px); background: var(--surface2); }
  .matiere-icone {
    font-family: 'Cormorant Garamond', serif;
    font-size: 22px; width: 44px; height: 44px;
    border: 1px solid; border-radius: 10px;
    display: flex; align-items: center; justify-content: center; flex-shrink: 0;
  }
  .matiere-body { flex: 1; }
  .matiere-nom { display: block; font-size: 14px; font-weight: 500; margin-bottom: 3px; }
  .matiere-counts { font-size: 12px; color: var(--text-dim); }
  .sep { margin: 0 4px; }
  .matiere-arrow { font-size: 16px; margin-left: auto; opacity: 0.5; transition: opacity 0.15s; }
  .matiere-card:hover .matiere-arrow { opacity: 1; }

  /* ANIMATIONS */
  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(14px); }
    to   { opacity: 1; transform: translateY(0); }
  }
  .stats-row      { animation: fadeUp .45s ease both; }
  .two-col        { animation: fadeUp .45s .1s ease both; }
  .matieres-section { animation: fadeUp .45s .2s ease both; }

  ::-webkit-scrollbar { width: 6px; }
  ::-webkit-scrollbar-track { background: var(--bg); }
  ::-webkit-scrollbar-thumb { background: var(--border); border-radius: 99px; }
</style>


<script define:vars={{ fiches_recentes, matieres }}>
  // On importe D3.js de manière dynamique pour éviter les erreurs de chargement
  import("https://cdn.jsdelivr.net/npm/d3@7/+esm").then((d3) => {
    
    // 1. Préparation des données
    const nodes = [];
    const links = [];

    matieres.forEach(m => {
      nodes.push({ id: m.nom, label: m.nom, radius: 14, color: m.couleur, type: 'matiere' });
    });

    fiches_recentes.forEach(f => {
      nodes.push({ id: f.titre, label: f.titre, radius: 7, color: f.couleur, type: f.type });
      links.push({ source: f.titre, target: f.matiere });
    });

    // Ajout des points fictifs
    const prefixes = ["Chapitre", "Exo", "Brouillon", "Concept", "Théorème", "Note"];
    for (let i = 0; i < 50; i++) {
      const matiereAleatoire = matieres[Math.floor(Math.random() * matieres.length)];
      const fauxId = `${prefixes[Math.floor(Math.random() * prefixes.length)]} ${i + 1}`;
      
      nodes.push({ 
        id: fauxId, 
        label: "", 
        radius: Math.random() * 4 + 3, 
        color: matiereAleatoire.couleur, 
        type: 'fictif' 
      });
      links.push({ source: fauxId, target: matiereAleatoire.nom });
    }

    // 2. Configuration du SVG D3
    const container = document.getElementById('graph-container');
    
    // On s'assure d'avoir une taille valide (fallback à 600x300 si le CSS n'est pas encore prêt)
    const width = container.clientWidth || 600;
    const height = container.clientHeight || 300;

    // On vide le conteneur au cas où (pratique avec le hot-reload de Astro)
    container.innerHTML = "";

    const svg = d3.select("#graph-container")
      .append("svg")
      .attr("width", "100%")
      .attr("height", "100%")
      .attr("viewBox", `0 0 ${width} ${height}`) // Utilisation de viewBox pour la responsivité
      .call(d3.zoom().scaleExtent([0.3, 4]).on("zoom", (event) => {
         g.attr("transform", event.transform);
      }))
      .append("g");

    const g = svg.append("g");

    // 3. Moteur de simulation physique
// 3. Moteur de simulation physique
    const simulation = d3.forceSimulation(nodes)
      // Maintient les points d'un même îlot proches (ex: 20)
      .force("link", d3.forceLink(links).id(d => d.id).distance(20))
      
      // Répulsion locale, mais on limite la portée avec distanceMax(150)
      // Comme ça, les îlots ne se repoussent plus à l'infini
      .force("charge", d3.forceManyBody().strength(-50).distanceMax(150))
      
      // Centre basique
      .force("center", d3.forceCenter(width / 2, height / 2))
      
      // Empêche les points de se chevaucher
      .force("collide", d3.forceCollide().radius(d => d.radius + 2))
      
      // NOUVEAU : Gravité pour rapprocher les îlots entre eux
      .force("x", d3.forceX(width / 2).strength(0.06))
      .force("y", d3.forceY(height / 2).strength(0.06));

    // 4. Dessin des liens
    const link = g.append("g")
      .selectAll("line")
      .data(links)
      .join("line")
      .attr("stroke", "#3d3a50")
      .attr("stroke-width", 1)
      .attr("stroke-opacity", 0.4);

    // 5. Dessin des nœuds
    const node = g.append("g")
      .selectAll("circle")
      .data(nodes)
      .join("circle")
      .attr("r", d => d.radius)
      .attr("fill", d => d.color)
      .attr("stroke", "#16161d")
      .attr("stroke-width", 1.5)
      .call(drag(simulation));

    // 6. Ajout des labels
    const text = g.append("g")
      .selectAll("text")
      .data(nodes.filter(n => n.label !== ""))
      .join("text")
      .text(d => d.label)
      .attr("font-family", "Outfit, sans-serif")
      .attr("font-size", d => d.type === 'matiere' ? "13px" : "11px")
      .attr("font-weight", d => d.type === 'matiere' ? "500" : "300")
      .attr("fill", "#e8e4da")
      .attr("dx", d => d.radius + 6)
      .attr("dy", 4)
      .style("pointer-events", "none")
      .style("opacity", 0.9)
      .style("text-shadow", "0 1px 3px rgba(0,0,0,0.8)");

    // 7. Mise à jour des positions
    simulation.on("tick", () => {
      link
        .attr("x1", d => d.source.x)
        .attr("y1", d => d.source.y)
        .attr("x2", d => d.target.x)
        .attr("y2", d => d.target.y);

      node
        .attr("cx", d => d.x)
        .attr("cy", d => d.y);

      text
        .attr("x", d => d.x)
        .attr("y", d => d.y);
    });

    // 8. Gestion du Drag & Drop
    function drag(simulation) {
      function dragstarted(event) {
        if (!event.active) simulation.alphaTarget(0.3).restart();
        event.subject.fx = event.subject.x;
        event.subject.fy = event.subject.y;
        container.style.cursor = "grabbing";
      }
      function dragged(event) {
        event.subject.fx = event.x;
        event.subject.fy = event.y;
      }
      function dragended(event) {
        if (!event.active) simulation.alphaTarget(0);
        event.subject.fx = null;
        event.subject.fy = null;
        container.style.cursor = "grab";
      }
      return d3.drag()
        .on("start", dragstarted)
        .on("drag", dragged)
        .on("end", dragended);
    }
    
  }).catch(error => {
    console.error("Erreur lors du chargement de D3.js :", error);
  });
</script>

</body>
</html>