---
/**
 * pages/index.astro — Dashboard home
 *
 * This file is intentionally thin.
 * Its only responsibilities are:
 *   1. Import static data
 *   2. Choose which components to render and in what order
 *   3. Pass data down via props
 *
 * All styles, logic, and markup live in the components themselves.
 */

import DashboardLayout        from '../layouts/DashboardLayout.astro';
import Sidebar                from '../components/layout/Sidebar.astro';
import Topbar                 from '../components/layout/Topbar.astro';
import StatsRow               from '../components/dashboard/StatsRow.astro';
import KnowledgeGraphPanel    from '../components/dashboard/KnowledgeGraphPanel.astro';
import ProgressPanel          from '../components/dashboard/ProgressPanel.astro';
import MatieresGrid           from '../components/dashboard/MatieresGrid.astro';

import { MATIERES, FICHES_RECENTES, STATS } from '../data/studyvault';

const today = new Date().toLocaleDateString('fr-FR', {
  weekday: 'long',
  day:     'numeric',
  month:   'long',
  year:    'numeric',
});
---

<DashboardLayout title="Accueil">
  <Sidebar activePath="/" />

  <main class="main">
    <Topbar
      title="Accueil"
      date={today}
      ctaLabel="Nouveau"
      ctaHref="/nouveau"
    />

    <StatsRow stats={STATS} />

    <!-- Two-column middle row -->
    <div class="two-col animate-fade-up-delay-1">
      <KnowledgeGraphPanel
        matieres={MATIERES}
        ficheRecentes={FICHES_RECENTES}
        viewAllHref="/tous"
      />

      <ProgressPanel
        matieres={MATIERES}
        maxFiches={20}
        limit={4}
      />
    </div>

    <MatieresGrid matieres={MATIERES} manageHref="/matieres" />
  </main>
</DashboardLayout>

<style>
  .main {
    flex: 1;
    padding: var(--space-8) 36px;
    max-width: calc(100vw - var(--sidebar-width));
    overflow-y: auto;
  }

  .two-col {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-5);
    margin-bottom: var(--space-8);
  }

  @media (max-width: 900px) {
    .main    { max-width: 100vw; padding: var(--space-5); }
    .two-col { grid-template-columns: 1fr; }
  }
</style>
